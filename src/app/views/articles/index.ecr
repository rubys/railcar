<div class="flex justify-between items-center">
  <h1>Articles</h1>
  <a href="<%= new_article_path %>" class="btn btn-primary">New article</a>
</div>

<div id="articles">
  <% if articles.empty? %>
    <p>No articles found.</p>
  <% else %>
    <% articles.each do |article| %>
      <%= render_article_partial(article) %>
    <% end %>
  <% end %>
</div>
